{
  "manifest_version": 3,
  "name": "kiwify-doutor-ie",
  "version": "0.1.0",
  "description": "Extensão que permite visualizar o id dos membros dos cursos da Kiwify.",
  "permissions": ["storage", "activeTab", "scripting", "declarativeContent"],
  "host_permissions": ["https://dashboard.kiwify.com/*"],
  "action": {
    "default_title": "kiwify-doutor-ie",
    "default_icon": {
      "16": "icons/icon-16.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://dashboard.kiwify.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://dashboard.kiwify.com/*"],
      "js": ["injected.js"],
      "run_at": "document_start",
      "world": "MAIN"
    }
  ],
  "options_page": "options.html",
  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  }
}
